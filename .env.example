# Copy this file to .env and fill in your real key.
# Do not commit .env.

OPENAI_API_KEY=your-kimi-api-key
OPENAI_BASE_URL=https://api.kimi.com/coding/v1
OPENAI_MODEL=your-kimi-model-name

# Optional: usage/balance page.
# Kimi balance can use a separate key, or falls back to OPENAI_API_KEY when OPENAI_BASE_URL is a Kimi/Moonshot endpoint.
KIMI_API_KEY=your-kimi-api-key
KIMI_BALANCE_BASE_URL=https://api.moonshot.cn/v1

# OpenAI organization API costs require an Admin Key.
# ChatGPT Plus/Pro app subscription message balance is not exposed through this API.
OPENAI_ADMIN_KEY=your-openai-admin-key
OPENAI_USAGE_DAYS=30
