# Copy this file to .env and fill in your real key.
# Do not commit .env.

OPENAI_API_KEY=your-bailian-coding-plan-key
OPENAI_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
OPENAI_MODEL=qwen3-coder-plus

# Optional: Coding Plan usage page.
# Kimi Coding Plan usage. If omitted, the app can fall back to KIMI_API_KEY or a Kimi OPENAI_API_KEY.
KIMI_CODING_API_KEY=your-kimi-coding-api-key
KIMI_CODING_USAGE_URL=https://api.kimi.com/coding/v1/usages

# Codex / GPT Coding usage. Keep this only in .env.
CODEX_ACCESS_TOKEN=your-codex-access-token
